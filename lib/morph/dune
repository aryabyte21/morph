(library
 (name morph)
 (public_name morph)
 (libraries base eio eio_main yojson logs fmt unix incremental domainslib)
 (foreign_archives ts_runtime ts_lang_typescript ts_lang_python ts_lang_tsx)
 (foreign_stubs
  (language c)
  (names ts_stubs)
  (flags
   (:standard -I %{workspace_root}/lib/runtime/include))))
