(rule
 (targets libts_runtime.a dllts_runtime.so)
 (deps
  (source_tree ../runtime))
 (action
  (no-infer
   (progn
    (run cc -O2 -fPIC -std=c11
         -I %{workspace_root}/lib/runtime/include
         -I %{workspace_root}/lib/runtime/src
         -c %{workspace_root}/lib/runtime/src/lib.c
         -o ts_runtime.o)
    (run ar rcs libts_runtime.a ts_runtime.o)
    (run cc -shared -o dllts_runtime.so ts_runtime.o)))))

(rule
 (targets libts_lang_typescript.a dllts_lang_typescript.so)
 (deps
  (source_tree ../grammars/typescript))
 (action
  (no-infer
   (progn
    (run cc -O2 -fPIC
         -I %{workspace_root}/lib/grammars/typescript
         -I %{workspace_root}/lib/grammars/typescript/tree_sitter
         -c %{workspace_root}/lib/grammars/typescript/parser.c
         -o ts_parser.o)
    (run cc -O2 -fPIC
         -I %{workspace_root}/lib/grammars/typescript
         -I %{workspace_root}/lib/grammars/typescript/tree_sitter
         -c %{workspace_root}/lib/grammars/typescript/scanner.c
         -o ts_scanner.o)
    (run ar rcs libts_lang_typescript.a ts_parser.o ts_scanner.o)
    (run cc -shared -o dllts_lang_typescript.so ts_parser.o ts_scanner.o)))))

